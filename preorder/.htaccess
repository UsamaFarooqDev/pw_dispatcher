# Route preorder/{id} to index.php so PHP can serve the page
# Without this, live Apache returns 404 because no file/dir named {id} exists.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /preorder/
    # If the request is not for an existing file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Send to index.php (REQUEST_URI is unchanged, so PHP still gets the ride id from the path)
    RewriteRule ^([^/]+)/?$ index.php [L,QSA]
</IfModule>
